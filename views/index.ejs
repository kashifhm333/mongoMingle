<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/stylesheets/style.css">

</head>
<body>
    <div class="w-full h-full bg-zinc-900 text-white">
        <h1 class="text-2xl font-bold">Create User</h1>
        <a href="/read" class="text-blue-500 hover:text-blue-700">View Users</a>
        <form action="/create" method="POST">
            <input type="text" class="px-5 py-2 border-2 border-zinc-800 mt-3 mx-2 rounded-lg bg-transparent" name="name" placeholder="Name">
            <input type="text" class="px-5 py-2 border-2 border-zinc-800 mt-3 mx-2 rounded-lg bg-transparent" name="email" placeholder="Email">
            <input type="text" class="px-5 py-2 border-2 border-zinc-800 mt-3 mx-2 rounded-lg bg-transparent" name="image" placeholder="Image Url">
            <input type="submit" value="Create" class="bg-blue-700 hover:bg-blue-800 text-white font-bold py-2 px-4 rounded">
        </form>
    </div>
    
</body>
</html>