<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/stylesheets/style.css">


</head>

<body>
    <div class="w-full h-full bg-zinc-900 text-white">
        <a href="/" class="text-blue-500 hover:text-blue-700">Back to Create User</a>
        <h1 class="text-2xl font-bold">View Users</h1>
        <div class="users flex flex-wrap gap-5 ">
           <% users.forEach(user => { %>
                <div class="user max-w-72 p-4 bg-zinc-800 rounded-lg">
                    <div class="w-full h-72 rounded-lg bg-zinc-700 overflow-hidden">
                        <img src="<%= user.image %>" class="w-full h-full object-cover" alt="<%= user.name %>">
                    </div>
                    <h3 class="text-xl mt-3 tracking-tighter"><%= user.name %></h3>
                    <h5 class="text-zinc-500"><%= user.email %></h5>
                    <div class="flex gap-3 mt-5">
                        <a href="/edit/<%= user._id %>" class="text-blue-500 hover:text-blue-700">Edit User</a>
                        <a href="/delete/<%= user._id %>" class="text-red-500 hover:text-red-700">Delete User</a>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</body>

</html>